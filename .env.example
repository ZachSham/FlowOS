ANTHROPIC_API_KEY=
OPENAI_API_KEY=
FLOWOS_WS_PORT=7331
FLOWOS_EXTENSION_TOKEN=

# LLM orchestrator provider: "anthropic" (default) or "openai"
ORCHESTRATOR_PROVIDER=anthropic

# Override the default model for the chosen provider
# Anthropic default: claude-sonnet-4-0
# OpenAI default: gpt-4.1
ORCHESTRATOR_MODEL=
