OPENAI_API_KEY=
FLOWOS_WS_PORT=7331
FLOWOS_EXTENSION_TOKEN=
FLOWOS_MEMORY_PATH=

# Override the default model (default: gpt-4.1-mini)
OPENAI_MODEL=

# Local STT via whisper.cpp (optional — if set, skips OpenAI Whisper API)
# Install: brew install whisper-cpp ffmpeg
# FLOWOS_WHISPER_BIN=/opt/homebrew/bin/whisper-cli
# FLOWOS_WHISPER_MODEL=/path/to/ggml-base.en.bin
# FLOWOS_WHISPER_THREADS=4
# FLOWOS_WHISPER_LANGUAGE=en
# FLOWOS_FFMPEG_BIN=ffmpeg
