{
  "name": "@flowos/extension-vscode",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.99.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "flowos.pushSnapshot",
        "title": "FlowOS: Push Snapshot"
      }
    ],
    "configuration": {
      "title": "FlowOS",
      "properties": {
        "flowos.token": {
          "type": "string",
          "default": "",
          "description": "Optional shared secret used for authenticating with the local FlowOS realtime server."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@flowos/shared": "*",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "@types/vscode": "^1.99.1",
    "typescript": "^5.8.3"
  }
}
