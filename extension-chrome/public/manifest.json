{
  "manifest_version": 3,
  "name": "FlowOS Chrome Bridge",
  "version": "0.2.0",
  "description": "Connects Chrome tabs and browser errors to the local FlowOS menubar app.",
  "permissions": ["tabs", "tabGroups", "storage"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1:4789/*", "http://localhost:4789/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "FlowOS"
  }
}
